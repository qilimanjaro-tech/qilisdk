msgid "Core"
msgstr "Core"

#~ msgid ""
#~ "The :mod:`qilisdk.core` layer underpins both"
#~ " the digital and analog stacks. It"
#~ " provides symbolic variables, optimization "
#~ "models, sparse quantum tensors, and the"
#~ " :mod:`~qilisdk.core.parameterizable.Parameterizable` mixin"
#~ " used throughout the SDK."
#~ msgstr ""
#~ "La capa :mod:`qilisdk.core` és la base"
#~ " tant de les piles digital com "
#~ "analògica. Proporciona variables simbòliques, "
#~ "models d'optimització, tensors quàntics "
#~ "dispersos i el mixin "
#~ ":mod:`~qilisdk.core.parameterizable.Parameterizable` utilitzat"
#~ " arreu del SDK."

#~ msgid "Highlights:"
#~ msgstr "Aspectes destacats:"

#~ msgid ""
#~ ":mod:`~qilisdk.core.variables` supplies binary, "
#~ "spin, continuous, and parameter variables "
#~ "plus algebraic helpers "
#~ "(:class:`~qilisdk.core.variables.Term`, comparison "
#~ "factories, encodings)."
#~ msgstr ""
#~ ":mod:`~qilisdk.core.variables` proporciona variables "
#~ "binàries, de spin, contínues i de "
#~ "paràmetre, a més d'assistents algebraics "
#~ "(:class:`~qilisdk.core.variables.Term`, fàbriques de "
#~ "comparació, codificacions)."

#~ msgid ""
#~ ":mod:`~qilisdk.core.model` builds constrained "
#~ "optimization programs and offers tools "
#~ "to automatically convert the model to"
#~ " :class:`~qilisdk.core.model.QUBO` format if the"
#~ " constraints are linear."
