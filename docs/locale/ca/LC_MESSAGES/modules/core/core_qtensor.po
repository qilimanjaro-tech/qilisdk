msgstr "**Sortida**"

#: ../../modules/core/core_qtensor.rst:57
msgid "Helper constructors"
msgstr "Constructors auxiliars"

#: ../../modules/core/core_qtensor.rst:59
msgid "There are also several constructors for common quantum objects:"
msgstr "També hi ha diversos constructors per a objectes quàntics habituals:"

#: ../../modules/core/core_qtensor.rst:61
msgid ":func:`~qilisdk.core.qtensor.ket` for computational basis kets"
msgstr ":func:`~qilisdk.core.qtensor.ket` per a kets de la base computacional"

#: ../../modules/core/core_qtensor.rst:62
msgid ":func:`~qilisdk.core.qtensor.bra` for computational basis bras"
msgstr ":func:`~qilisdk.core.qtensor.bra` per a bras de la base computacional"

#: ../../modules/core/core_qtensor.rst:63
msgid ""
":func:`~qilisdk.core.qtensor.basis_state` for N-dimensional basis states "
"with a single 1 at the specified index"
msgstr ""
":func:`~qilisdk.core.qtensor.basis_state` per a estats de base "
"N-dimensionals amb un únic 1 a l'índex especificat"

#: ../../modules/core/core_qtensor.rst:64
msgid ""
":func:`~qilisdk.core.qtensor.identity` for identity operators of "
"specified dimension"
msgstr ""
":func:`~qilisdk.core.qtensor.identity` per a operadors identitat de la "
"dimensió especificada"

#: ../../modules/core/core_qtensor.rst:65
msgid ""
":func:`~qilisdk.core.qtensor.zero` for generating statevectors in the "
"all-zero state."
msgstr ""
":func:`~qilisdk.core.qtensor.zero` per generar vectors d'estat en l'estat "
"de tot zeros."

#: ../../modules/core/core_qtensor.rst:66
msgid ""
":func:`~qilisdk.core.qtensor.one` for generating statevectors in the all-"
"one state."
msgstr ""
":func:`~qilisdk.core.qtensor.one` per generar vectors d'estat en l'estat "
"de tot uns."

#: ../../modules/core/core_qtensor.rst:67
msgid ""
":func:`~qilisdk.core.qtensor.ghz` for generating GHZ states of specified "
"number of qubits"
msgstr ""
":func:`~qilisdk.core.qtensor.ghz` per generar estats GHZ del nombre de "
"qubits especificat"

#: ../../modules/core/core_qtensor.rst:68
msgid ""
":meth:`~qilisdk.core.qtensor.QTensor.uniform` for generating uniform "
"superposition states of specified number of qubits"
msgstr ""
":meth:`~qilisdk.core.qtensor.QTensor.uniform` per generar estats de "
"superposició uniforme del nombre de qubits especificat"

#: ../../modules/core/core_qtensor.rst:106
msgid "Quantum Object Properties & Operations"
msgstr "Propietats i operacions d'objectes quàntics"

#: ../../modules/core/core_qtensor.rst:108
msgid "All data are stored sparsely, but you can retrieve dense or sparse views:"
msgstr ""
"Totes les dades s'emmagatzemen de forma dispersa, però podeu recuperar "
"vistes denses o disperses:"

#: ../../modules/core/core_qtensor.rst:110
msgid ""
":attr:`.data<qilisdk.core.qtensor.QTensor.data>`: get the underlying "
"sparse matrix (SciPy CSR format)"
msgstr ""
":attr:`.data<qilisdk.core.qtensor.QTensor.data>`: obté la matriu dispersa"
" subjacent (format SciPy CSR)"

#: ../../modules/core/core_qtensor.rst:111
msgid ""
":meth:`.dense()<qilisdk.core.qtensor.QTensor.dense>`: convert to a dense "
"NumPy array (use with caution for large tensors)"
msgstr ""
":meth:`.dense()<qilisdk.core.qtensor.QTensor.dense>`: converteix a un "
"array dens de NumPy (useu amb precaució per a tensors grans)"

#: ../../modules/core/core_qtensor.rst:112
msgid "or directly accessing elements by value with ``qtensor[i, j]``"
msgstr "o accedint directament als elements per valor amb ``qtensor[i, j]``"

#: ../../modules/core/core_qtensor.rst:114
msgid "Common matrix operations are also available:"
msgstr "També estan disponibles les operacions matricials habituals:"

#: ../../modules/core/core_qtensor.rst:116
msgid ""
":meth:`.adjoint()<qilisdk.core.qtensor.QTensor.adjoint>`: conjugate "
"transpose"
msgstr ""
":meth:`.adjoint()<qilisdk.core.qtensor.QTensor.adjoint>`: transposada "
"conjugada"

#: ../../modules/core/core_qtensor.rst:117
msgid ""
":meth:`.conjugate()<qilisdk.core.qtensor.QTensor.conjugate>`: element-"
"wise complex conjugate"
msgstr ""
":meth:`.conjugate()<qilisdk.core.qtensor.QTensor.conjugate>`: conjugada "
"complexa element a element"

#: ../../modules/core/core_qtensor.rst:118
msgid ""
":meth:`.transpose()<qilisdk.core.qtensor.QTensor.transpose>`: matrix "
"transpose"
msgstr ""
":meth:`.transpose()<qilisdk.core.qtensor.QTensor.transpose>`: transposada"
" de la matriu"

#: ../../modules/core/core_qtensor.rst:119
msgid ":meth:`.exp()<qilisdk.core.qtensor.QTensor.exp>`: matrix exponential"
msgstr ":meth:`.exp()<qilisdk.core.qtensor.QTensor.exp>`: exponencial matricial"

#: ../../modules/core/core_qtensor.rst:120
msgid ":meth:`.log()<qilisdk.core.qtensor.QTensor.log>`: matrix logarithm"
msgstr ":meth:`.log()<qilisdk.core.qtensor.QTensor.log>`: logaritme matricial"

#: ../../modules/core/core_qtensor.rst:121
msgid ":meth:`.sqrt()<qilisdk.core.qtensor.QTensor.sqrt>`: matrix square root"
msgstr ""
":meth:`.sqrt()<qilisdk.core.qtensor.QTensor.sqrt>`: arrel quadrada "
"matricial"

#: ../../modules/core/core_qtensor.rst:122
msgid ""
":meth:`.rank()<qilisdk.core.qtensor.QTensor.rank>`: compute the rank of "
"the operator"
msgstr ""
":meth:`.rank()<qilisdk.core.qtensor.QTensor.rank>`: calcula el rang de "
"l'operador"

#: ../../modules/core/core_qtensor.rst:123
msgid ":meth:`.pow(exponent)<qilisdk.core.qtensor.QTensor.pow>`: matrix power"
msgstr ""
":meth:`.pow(exponent)<qilisdk.core.qtensor.QTensor.pow>`: potència "
"matricial"

#: ../../modules/core/core_qtensor.rst:124
msgid ""
":meth:`.norm(order=\"l2\")<qilisdk.core.qtensor.QTensor.norm>`: vector or"
" matrix norm"
msgstr ""
":meth:`.norm(order=\"l2\")<qilisdk.core.qtensor.QTensor.norm>`: norma "
"vectorial o matricial"

#: ../../modules/core/core_qtensor.rst:125
msgid ""
":meth:`.normalized(order='l2')<qilisdk.core.qtensor.QTensor.normalized>`:"
" normalize to unit norm"
msgstr ""
":meth:`.normalized(order='l2')<qilisdk.core.qtensor.QTensor.normalized>`:"
" normalitza a norma unitària"

#: ../../modules/core/core_qtensor.rst:126
msgid ""
":meth:`.eig()<qilisdk.core.qtensor.QTensor.eig>`: get the eigenvalues and"
" eigenvectors"
msgstr ""
":meth:`.eig()<qilisdk.core.qtensor.QTensor.eig>`: obté els valors propis "
"i els vectors propis"

#: ../../modules/core/core_qtensor.rst:127
msgid ""
":meth:`.trace()<qilisdk.core.qtensor.QTensor.trace>`: compute the trace "
"of an operator"
msgstr ""
":meth:`.trace()<qilisdk.core.qtensor.QTensor.trace>`: calcula la traça "
"d'un operador"

#: ../../modules/core/core_qtensor.rst:128
msgid ""
":meth:`.dot(other)<qilisdk.core.qtensor.QTensor.dot>`: Frobenius inner "
"product with another QTensor"
msgstr ""
":meth:`.dot(other)<qilisdk.core.qtensor.QTensor.dot>`: producte intern de"
" Frobenius amb un altre QTensor"

#: ../../modules/core/core_qtensor.rst:130
msgid "As well as some quantum-specific transformations:"
msgstr "Així com algunes transformacions específiques de la mecànica quàntica:"

#: ../../modules/core/core_qtensor.rst:132
msgid ""
":meth:`.entropy_von_neumann()<qilisdk.core.qtensor.QTensor.entropy_von_neumann>`:"
" compute the von Neumann entropy of a density matrix"
msgstr ""
":meth:`.entropy_von_neumann()<qilisdk.core.qtensor.QTensor.entropy_von_neumann>`:"
" calcula l'entropia de von Neumann d'una matriu de densitat"

#: ../../modules/core/core_qtensor.rst:133
msgid ""
":meth:`.entropy_renyi(alpha)<qilisdk.core.qtensor.QTensor.entropy_renyi>`:"
" compute the Rényi entropy of a density matrix for a given order alpha"
msgstr ""
":meth:`.entropy_renyi(alpha)<qilisdk.core.qtensor.QTensor.entropy_renyi>`:"
" calcula l'entropia de Rényi d'una matriu de densitat per a un ordre "
"alpha donat"

#: ../../modules/core/core_qtensor.rst:134
msgid ""
":meth:`.commutator(other)<qilisdk.core.qtensor.QTensor.commutator>`: "
"compute the commutator with another operator"
msgstr ""
":meth:`.commutator(other)<qilisdk.core.qtensor.QTensor.commutator>`: "
"calcula el commutador amb un altre operador"

#: ../../modules/core/core_qtensor.rst:135
msgid ""
":meth:`.anticommutator(other)<qilisdk.core.qtensor.QTensor.anticommutator>`:"
" compute the anticommutator with another operator"
msgstr ""
":meth:`.anticommutator(other)<qilisdk.core.qtensor.QTensor.anticommutator>`:"
" calcula l'anticommutador amb un altre operador"

#: ../../modules/core/core_qtensor.rst:136
msgid ""
":meth:`.fidelity(other)<qilisdk.core.qtensor.QTensor.fidelity>`: compute "
