#: ../../modules/analog/analog.rst:2
msgid "Analog"
msgstr "Analògic"

#~ msgid ""
#~ "The :mod:`qilisdk.analog` layer lets you "
#~ "build symbolic Hamiltonians and time-"
#~ "dependent schedules that can be "
#~ "simulated or submitted to Qili backends."
#~ " Its core types are "
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian` and "
#~ ":class:`~qilisdk.analog.schedule.Schedule`."
#~ msgstr ""
#~ "La capa :mod:`qilisdk.analog` permet construir"
#~ " Hamiltonians simbòlics i esquemes "
#~ "dependents del temps que es poden "
#~ "simular o enviar als backends de "
#~ "Qili. Els seus tipus principals són "
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian` i "
#~ ":class:`~qilisdk.analog.schedule.Schedule`."

#~ msgid ""
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian`: Tools to"
#~ " build arbitrary Hamiltonians using "
#~ "symbolic Pauli operators."
#~ msgstr ""
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian`: Eines "
#~ "per construir Hamiltonians arbitraris "
#~ "utilitzant operadors de Pauli simbòlics."

#~ msgid ""
#~ ":class:`~qilisdk.analog.schedule.Schedule`: Flexible "
#~ "time-dependent evolution with callable/interval"
#~ " coefficients and step/linear interpolation."
#~ msgstr ""
#~ ":class:`~qilisdk.analog.schedule.Schedule`: Evolució "
#~ "flexible dependent del temps amb "
#~ "coeficients callable/interval i interpolació "
#~ "escalonada/lineal."

#~ msgid "Hamiltonian"
#~ msgstr "Hamiltonià"

#~ msgid ""
#~ "The :class:`~qilisdk.analog.hamiltonian.Hamiltonian` class"
#~ " represents a symbolic Hamiltonian as "
#~ "a sum of weighted Pauli operators. "
#~ "You can create Hamiltonians using the"
#~ " built-in Pauli operators and combine"
#~ " them with standard arithmetic operations."
#~ msgstr ""
#~ "La classe :class:`~qilisdk.analog.hamiltonian.Hamiltonian`"
#~ " representa un Hamiltonià simbòlic com "
#~ "una suma d'operadors de Pauli ponderats."
#~ " Es poden crear Hamiltonians utilitzant "
#~ "els operadors de Pauli integrats i "
#~ "combinar-los amb operacions aritmètiques "
#~ "estàndard."

#~ msgid "**Common constructors**"
#~ msgstr "**Constructors comuns**"

#~ msgid ""
#~ "``X(i)``, ``Y(i)``, ``Z(i)``, ``I(i)`` "
#~ "produces a Hamiltonian with a single-"
#~ "qubit Pauli."
#~ msgstr ""
#~ "``X(i)``, ``Y(i)``, ``Z(i)``, ``I(i)`` "
#~ "produeix un Hamiltonià amb un Pauli "
#~ "d'un sol qubit."

#~ msgid ""
#~ "Construction using arithmetic operations. The"
#~ " operations follow Python syntax, for "
#~ "example: ``2 * Z(0) + Z(1)`` and"
#~ " ``Z(0) * Z(1)`` build multi-qubit"
#~ " Hamiltonian."
#~ msgstr ""
#~ "Construcció mitjançant operacions aritmètiques. "
#~ "Les operacions segueixen la sintaxi de"
#~ " Python, per exemple: ``2 * Z(0) "
#~ "+ Z(1)`` i ``Z(0) * Z(1)`` "
#~ "construeixen Hamiltonians multi-qubit."

