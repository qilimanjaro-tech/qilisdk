#~ msgid ""
#~ ":class:`~qilisdk.noise.gaussian_perturbation.GaussianPerturbation` "
#~ "represents a noise model that adds "
#~ "Gaussian-distributed perturbations to the "
#~ "parameters of gates or Hamiltonian terms"
#~ " in a quantum circuit or schedule."
#~ " This simulates imperfections in control"
#~ " signals that can lead to deviations"
#~ " from the intended operations. The "
#~ "perturbations are drawn from a Gaussian"
#~ " distribution with a specified standard "
#~ "deviation:"
#~ msgstr ""
#~ ":class:`~qilisdk.noise.gaussian_perturbation.GaussianPerturbation` "
#~ "representa un model de soroll que "
#~ "afegeix pertorbacions de distribució gaussiana"
#~ " als paràmetres de portes o termes"
#~ " de l'Hamiltonià en un circuit "
#~ "quàntic o una programació. Això simula"
#~ " imperfeccions en els senyals de "
#~ "control que poden conduir a desviacions"
#~ " de les operacions previstes. Les "
#~ "pertorbacions s'extreuen d'una distribució "
#~ "gaussiana amb una desviació estàndard "
#~ "especificada:"

#~ msgid "\\delta \\theta \\sim \\mathcal{N}(\\mu, \\sigma^2),"
#~ msgstr "\\delta \\theta \\sim \\mathcal{N}(\\mu, \\sigma^2),"

#~ msgid ""
#~ "where :math:`\\sigma` is the standard "
#~ "deviation of the perturbations and "
#~ ":math:`\\mu` is the mean (defaulting to"
#~ " 0)."
#~ msgstr ""
#~ "on :math:`\\sigma` és la desviació "
#~ "estàndard de les pertorbacions i "
#~ ":math:`\\mu` és la mitjana (per defecte"
#~ " 0)."

