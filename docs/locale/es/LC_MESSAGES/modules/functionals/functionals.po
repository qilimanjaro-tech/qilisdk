#~ msgid ""
#~ "The "
#~ ":class:`~qilisdk.functionals.analog_evolution.AnalogEvolution` "
#~ "functional simulates analog evolution of "
#~ "a quantum system under one or more"
#~ " Hamiltonians, following a specified "
#~ "time-dependent schedule. Its parameter "
#~ "interface mirrors that of "
#~ ":class:`~qilisdk.analog.schedule.Schedule`, making it "
#~ "straightforward to sweep control waveforms "
#~ "or pulse amplitudes from classical "
#~ "optimizers."
#~ msgstr ""
#~ "El funcional "
#~ ":class:`~qilisdk.functionals.analog_evolution.AnalogEvolution` "
#~ "simula la evolución analógica de un "
#~ "sistema cuántico bajo uno o más "
#~ "Hamiltonianos, siguiendo un esquema "
#~ "dependiente del tiempo especificado. Su "
#~ "interfaz de parámetros refleja la de "
#~ ":class:`~qilisdk.analog.schedule.Schedule`, lo que "
#~ "facilita el barrido de formas de "
#~ "onda de control o amplitudes de "
#~ "pulso desde optimizadores clásicos."

