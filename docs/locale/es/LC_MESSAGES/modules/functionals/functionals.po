#~ "Defines pre/post-processing, reservoir "
#~ "dynamics, observables, and reset policy."
#~ msgstr ""
#~ "**reservoir_layer** "
#~ "(:class:`~qilisdk.functionals.quantum_reservoirs.ReservoirLayer`): "
#~ "Define el pre/postprocesado, la dinámica "
#~ "del reservorio, los observables y la "
#~ "política de reinicio."

