#: ../../modules/core/core_model.rst:127
msgid ""
":func:`Model.random_ising(num_variables, coefficient_range, label, "
"seed)<qilisdk.core.model.Model.random_ising>` - Constructs a random Ising"
" model with specified parameters."
msgstr ""
":func:`Model.random_ising(num_variables, coefficient_range, label, "
"seed)<qilisdk.core.model.Model.random_ising>` - Construye un modelo de "
"Ising aleatorio con los parámetros especificados."

#: ../../modules/core/core_model.rst:128
msgid ""
":func:`Model.knapsack(values, weights, max_weight, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.knapsack>` - Constructs a "
"knapsack problem with given weights, values, and capacity."
msgstr ""
":func:`Model.knapsack(values, weights, max_weight, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.knapsack>` - Construye un "
"problema de la mochila con los pesos, valores y capacidad dados."

#: ../../modules/core/core_model.rst:129
msgid ""
":func:`Model.max_cut(edges, weights, "
"label)<qilisdk.core.model.Model.max_cut>` - Constructs a max cut problem "
"for a given graph."
msgstr ""
":func:`Model.max_cut(edges, weights, "
"label)<qilisdk.core.model.Model.max_cut>` - Construye un problema de corte"
" máximo para un grafo dado."

#: ../../modules/core/core_model.rst:130
msgid ""
":func:`Model.graph_coloring(graph, num_colors, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.graph_coloring>` - "
"Constructs a graph coloring problem for a given graph and number of "
"colors."
msgstr ""
":func:`Model.graph_coloring(graph, num_colors, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.graph_coloring>` - "
"Construye un problema de coloreado de grafos para un grafo y un número de "
"colores dados."

#: ../../modules/core/core_model.rst:131
msgid ""
":func:`Model.travelling_salesman(edges, distances, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.travelling_salesman>` - "
"Constructs a travelling salesman problem for a given distance matrix."
msgstr ""
":func:`Model.travelling_salesman(edges, distances, label, "
"lagrange_multiplier)<qilisdk.core.model.Model.travelling_salesman>` - "
"Construye un problema del viajante de comercio para una matriz de "
"distancias dada."

#: ../../modules/core/core_model.rst:132
msgid ""
":func:`Model.factoring(n, label)<qilisdk.core.model.Model.factoring>` - "
"Constructs a factoring problem for a given integer."
msgstr ""
":func:`Model.factoring(n, label)<qilisdk.core.model.Model.factoring>` - "
"Construye un problema de factorización para un entero dado."

