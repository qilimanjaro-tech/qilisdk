#: ../../modules/core/core_qtensor.rst:106
msgid "Quantum Object Properties & Operations"
msgstr "Propiedades y operaciones de objetos cuánticos"

#: ../../modules/core/core_qtensor.rst:108
msgid "All data are stored sparsely, but you can retrieve dense or sparse views:"
msgstr ""
"Todos los datos se almacenan en formato disperso, pero se pueden obtener "
"vistas densas o dispersas:"

#: ../../modules/core/core_qtensor.rst:110
msgid ""
":attr:`.data<qilisdk.core.qtensor.QTensor.data>`: get the underlying "
"sparse matrix (SciPy CSR format)"
msgstr ""
":attr:`.data<qilisdk.core.qtensor.QTensor.data>`: obtiene la matriz "
"dispersa subyacente (formato CSR de SciPy)"

#: ../../modules/core/core_qtensor.rst:111
msgid ""
":meth:`.dense()<qilisdk.core.qtensor.QTensor.dense>`: convert to a dense "
"NumPy array (use with caution for large tensors)"
msgstr ""
":meth:`.dense()<qilisdk.core.qtensor.QTensor.dense>`: convierte a un "
"array denso de NumPy (usar con precaución para tensores grandes)"

#: ../../modules/core/core_qtensor.rst:112
msgid "or directly accessing elements by value with ``qtensor[i, j]``"
msgstr "o accediendo directamente a elementos por valor con ``qtensor[i, j]``"

#: ../../modules/core/core_qtensor.rst:114
msgid "Common matrix operations are also available:"
msgstr "También están disponibles operaciones matriciales comunes:"

#: ../../modules/core/core_qtensor.rst:116
msgid ""
":meth:`.adjoint()<qilisdk.core.qtensor.QTensor.adjoint>`: conjugate "
"transpose"
msgstr ""
":meth:`.adjoint()<qilisdk.core.qtensor.QTensor.adjoint>`: traspuesta "
"conjugada"

#: ../../modules/core/core_qtensor.rst:117
msgid ""
":meth:`.conjugate()<qilisdk.core.qtensor.QTensor.conjugate>`: element-"
"wise complex conjugate"
msgstr ""
":meth:`.conjugate()<qilisdk.core.qtensor.QTensor.conjugate>`: conjugada "
"compleja elemento a elemento"

#: ../../modules/core/core_qtensor.rst:118
msgid ""
":meth:`.transpose()<qilisdk.core.qtensor.QTensor.transpose>`: matrix "
"transpose"
msgstr ""
":meth:`.transpose()<qilisdk.core.qtensor.QTensor.transpose>`: traspuesta "
"matricial"

#: ../../modules/core/core_qtensor.rst:119
msgid ":meth:`.exp()<qilisdk.core.qtensor.QTensor.exp>`: matrix exponential"
msgstr ":meth:`.exp()<qilisdk.core.qtensor.QTensor.exp>`: exponencial matricial"

#: ../../modules/core/core_qtensor.rst:120
msgid ":meth:`.log()<qilisdk.core.qtensor.QTensor.log>`: matrix logarithm"
msgstr ":meth:`.log()<qilisdk.core.qtensor.QTensor.log>`: logaritmo matricial"

#: ../../modules/core/core_qtensor.rst:121
msgid ":meth:`.sqrt()<qilisdk.core.qtensor.QTensor.sqrt>`: matrix square root"
msgstr ""
":meth:`.sqrt()<qilisdk.core.qtensor.QTensor.sqrt>`: raíz cuadrada "
"matricial"

#: ../../modules/core/core_qtensor.rst:122
msgid ""
":meth:`.rank()<qilisdk.core.qtensor.QTensor.rank>`: compute the rank of "
"the operator"
msgstr ""
":meth:`.rank()<qilisdk.core.qtensor.QTensor.rank>`: calcula el rango del "
"operador"

#: ../../modules/core/core_qtensor.rst:123
msgid ":meth:`.pow(exponent)<qilisdk.core.qtensor.QTensor.pow>`: matrix power"
msgstr ""
":meth:`.pow(exponent)<qilisdk.core.qtensor.QTensor.pow>`: potencia "
"matricial"

#: ../../modules/core/core_qtensor.rst:124
msgid ""
":meth:`.norm(order=\"l2\")<qilisdk.core.qtensor.QTensor.norm>`: vector or"
" matrix norm"
msgstr ""
":meth:`.norm(order=\"l2\")<qilisdk.core.qtensor.QTensor.norm>`: norma "
"vectorial o matricial"

#: ../../modules/core/core_qtensor.rst:125
msgid ""
":meth:`.normalized(order='l2')<qilisdk.core.qtensor.QTensor.normalized>`:"
" normalize to unit norm"
msgstr ""
":meth:`.normalized(order='l2')<qilisdk.core.qtensor.QTensor.normalized>`:"
" normaliza a norma unitaria"

#: ../../modules/core/core_qtensor.rst:126
msgid ""
":meth:`.eig()<qilisdk.core.qtensor.QTensor.eig>`: get the eigenvalues and"
" eigenvectors"
msgstr ""
":meth:`.eig()<qilisdk.core.qtensor.QTensor.eig>`: obtiene los valores "
"propios y vectores propios"

#: ../../modules/core/core_qtensor.rst:127
msgid ""
":meth:`.trace()<qilisdk.core.qtensor.QTensor.trace>`: compute the trace "
"of an operator"
msgstr ""
":meth:`.trace()<qilisdk.core.qtensor.QTensor.trace>`: calcula la traza de"
" un operador"

#: ../../modules/core/core_qtensor.rst:128
msgid ""
":meth:`.dot(other)<qilisdk.core.qtensor.QTensor.dot>`: Frobenius inner "
"product with another QTensor"
msgstr ""
":meth:`.dot(other)<qilisdk.core.qtensor.QTensor.dot>`: producto interior "
"de Frobenius con otro QTensor"

#: ../../modules/core/core_qtensor.rst:130
msgid "As well as some quantum-specific transformations:"
msgstr "Así como algunas transformaciones específicas para objetos cuánticos:"

#: ../../modules/core/core_qtensor.rst:132
msgid ""
":meth:`.entropy_von_neumann()<qilisdk.core.qtensor.QTensor.entropy_von_neumann>`:"
" compute the von Neumann entropy of a density matrix"
msgstr ""
":meth:`.entropy_von_neumann()<qilisdk.core.qtensor.QTensor.entropy_von_neumann>`:"
" calcula la entropía de von Neumann de una matriz de densidad"

#: ../../modules/core/core_qtensor.rst:133
msgid ""
":meth:`.entropy_renyi(alpha)<qilisdk.core.qtensor.QTensor.entropy_renyi>`:"
" compute the Rényi entropy of a density matrix for a given order alpha"
msgstr ""
":meth:`.entropy_renyi(alpha)<qilisdk.core.qtensor.QTensor.entropy_renyi>`:"
" calcula la entropía de Rényi de una matriz de densidad para un orden "
"alpha dado"

#: ../../modules/core/core_qtensor.rst:134
msgid ""
":meth:`.commutator(other)<qilisdk.core.qtensor.QTensor.commutator>`: "
"compute the commutator with another operator"
msgstr ""
":meth:`.commutator(other)<qilisdk.core.qtensor.QTensor.commutator>`: "
"calcula el conmutador con otro operador"

#: ../../modules/core/core_qtensor.rst:135
msgid ""
":meth:`.anticommutator(other)<qilisdk.core.qtensor.QTensor.anticommutator>`:"
" compute the anticommutator with another operator"
msgstr ""
":meth:`.anticommutator(other)<qilisdk.core.qtensor.QTensor.anticommutator>`:"
" calcula el anticonmutador con otro operador"

#: ../../modules/core/core_qtensor.rst:136
msgid ""
":meth:`.fidelity(other)<qilisdk.core.qtensor.QTensor.fidelity>`: compute "
