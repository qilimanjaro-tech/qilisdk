#~ "layers."
#~ msgstr ""
#~ "**problem_params**: Valores iniciales de los"
#~ " parámetros para los ángulos de "
#~ "evolución del Hamiltoniano del problema. "
#~ "Por defecto 0.0 para todas las "
#~ "capas."

#~ msgid ""
#~ "**mixer_params**: Initial parameter values for"
#~ " the mixer Hamiltonian evolution angles."
#~ " Defaults to 0.0 for all layers."
#~ msgstr ""
#~ "**mixer_params**: Valores iniciales de los "
#~ "parámetros para los ángulos de evolución"
#~ " del Hamiltoniano mezclador. Por defecto"
#~ " 0.0 para todas las capas."

