#: ../../modules/analog/analog.rst:2
msgid "Analog"
msgstr "Analógico"

#~ msgid ""
#~ "The :mod:`qilisdk.analog` layer lets you "
#~ "build symbolic Hamiltonians and time-"
#~ "dependent schedules that can be "
#~ "simulated or submitted to Qili backends."
#~ " Its core types are "
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian` and "
#~ ":class:`~qilisdk.analog.schedule.Schedule`."
#~ msgstr ""
#~ "La capa :mod:`qilisdk.analog` permite "
#~ "construir Hamiltonianos simbólicos y esquemas"
#~ " dependientes del tiempo que pueden "
#~ "simularse o enviarse a backends de "
#~ "Qili. Sus tipos principales son "
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian` y "
#~ ":class:`~qilisdk.analog.schedule.Schedule`."

#~ msgid ""
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian`: Tools to"
#~ " build arbitrary Hamiltonians using "
#~ "symbolic Pauli operators."
#~ msgstr ""
#~ ":class:`~qilisdk.analog.hamiltonian.Hamiltonian`: Herramientas"
#~ " para construir Hamiltonianos arbitrarios "
#~ "usando operadores de Pauli simbólicos."

#~ msgid ""
#~ ":class:`~qilisdk.analog.schedule.Schedule`: Flexible "
#~ "time-dependent evolution with callable/interval"
#~ " coefficients and step/linear interpolation."
#~ msgstr ""
#~ ":class:`~qilisdk.analog.schedule.Schedule`: Evolución "
#~ "flexible dependiente del tiempo con "
#~ "coeficientes callable/por intervalos e "
#~ "interpolación escalonada/lineal."

#~ msgid "Hamiltonian"
#~ msgstr "Hamiltoniano"

#~ msgid ""
#~ "The :class:`~qilisdk.analog.hamiltonian.Hamiltonian` class"
#~ " represents a symbolic Hamiltonian as "
#~ "a sum of weighted Pauli operators. "
#~ "You can create Hamiltonians using the"
#~ " built-in Pauli operators and combine"
#~ " them with standard arithmetic operations."
#~ msgstr ""
#~ "La clase :class:`~qilisdk.analog.hamiltonian.Hamiltonian`"
#~ " representa un Hamiltoniano simbólico como"
#~ " una suma de operadores de Pauli "
#~ "ponderados. Se pueden crear Hamiltonianos "
#~ "usando los operadores de Pauli "
#~ "integrados y combinarlos con operaciones "
#~ "aritméticas estándar."

#~ msgid "**Common constructors**"
#~ msgstr "**Constructores comunes**"

#~ msgid ""
#~ "``X(i)``, ``Y(i)``, ``Z(i)``, ``I(i)`` "
#~ "produces a Hamiltonian with a single-"
#~ "qubit Pauli."
#~ msgstr ""
#~ "``X(i)``, ``Y(i)``, ``Z(i)``, ``I(i)`` "
#~ "producen un Hamiltoniano con un Pauli"
#~ " de un solo cúbit."

#~ msgid ""
#~ "Construction using arithmetic operations. The"
#~ " operations follow Python syntax, for "
#~ "example: ``2 * Z(0) + Z(1)`` and"
#~ " ``Z(0) * Z(1)`` build multi-qubit"
#~ " Hamiltonian."
#~ msgstr ""
#~ "Construcción mediante operaciones aritméticas. "
#~ "Las operaciones siguen la sintaxis de"
#~ " Python, por ejemplo: ``2 * Z(0) "
#~ "+ Z(1)`` y ``Z(0) * Z(1)`` "
#~ "construyen Hamiltonianos de múltiples cúbits."

