#: ../../modules/readout/readout.rst:2
msgid "Readout"
msgstr "Readout"

#~ msgid ""
#~ "Readout is the mechanism that controls"
#~ " **what information is extracted from "
#~ "the quantum backend** after a functional"
#~ " is executed.  It is specified "
#~ "separately from the functional itself, "
#~ "so the same circuit or schedule "
#~ "can be measured in different ways "
#~ "without any code change to the "
#~ "functional."
#~ msgstr ""
#~ "La lectura es el mecanismo que "
#~ "controla **qué información se extrae del"
#~ " backend cuántico** tras la ejecución "
#~ "de un funcional. Se especifica de "
#~ "forma independiente al propio funcional, "
#~ "de modo que el mismo circuito o"
#~ " esquema puede medirse de diferentes "
#~ "maneras sin modificar el código del "
#~ "funcional."

#~ msgid ""
#~ "All uses start with an instance of"
#~ " the class "
#~ ":class:`~qilisdk.readout.readout_spec.Readout`."
#~ msgstr ""
#~ "Todos los usos comienzan con una "
#~ "instancia de la clase "
#~ ":class:`~qilisdk.readout.readout_spec.Readout`."

#~ msgid "Readout Builder"
#~ msgstr "Constructor de Lectura"

#~ msgid ""
#~ ":class:`~qilisdk.readout.readout_spec.Readout` is a "
#~ "builder that accumulates readout methods "
#~ "by chaining ``with_*`` calls.  Each call"
#~ " returns a *new* spec with one "
#~ "additional slot filled; the original "
#~ "object is never modified."
#~ msgstr ""
#~ ":class:`~qilisdk.readout.readout_spec.Readout` es un "
#~ "constructor que acumula métodos de "
#~ "lectura encadenando llamadas ``with_*``. Cada"
#~ " llamada devuelve una *nueva* "
#~ "especificación con un slot adicional "
#~ "rellenado; el objeto original nunca se"
#~ " modifica."

#~ msgid ""
#~ "The finished spec is passed to "
#~ ":meth:`~qilisdk.backends.backend.Backend.execute` (or "
#~ ":meth:`~qilisdk.speqtrum.speqtrum.SpeQtrum.submit` for "
#~ "remote hardware):"
#~ msgstr ""
#~ "La especificación terminada se pasa a"
#~ " :meth:`~qilisdk.backends.backend.Backend.execute` (o a"
#~ " :meth:`~qilisdk.speqtrum.speqtrum.SpeQtrum.submit` para "
#~ "hardware remoto):"

#~ msgid ""
#~ "At least one readout method must "
#~ "be added before calling ``execute``.  "
#~ "Passing an empty ``Readout()`` raises a"
#~ " ``ValueError``."
#~ msgstr ""
#~ "Debe añadirse al menos un método "
#~ "de lectura antes de llamar a "
#~ "``execute``. Pasar un ``Readout()`` vacío "
#~ "lanza un ``ValueError``."

#~ msgid "Readout Types"
#~ msgstr "Tipos de Lectura"

#~ msgid "Bitstring Measurement (with_sampling)"
#~ msgstr "Medición de Cadena de Bits (with_sampling)"

#~ msgid ""
#~ "Instructs the backend to perform "
#~ "``nshots`` projective measurements in the "
#~ "computational basis and collect the "
#~ "bitstring counts."
#~ msgstr ""
#~ "Indica al backend que realice ``nshots``"
#~ " mediciones proyectivas en la base "
#~ "computacional y recopile los conteos de"
#~ " cadenas de bits."

#~ msgid "**Parameters**"
#~ msgstr "**Parámetros**"

#~ msgid ""
#~ "**nshots** (``int``): Number of measurement"
#~ " shots.  Must be a positive integer."
#~ msgstr ""
#~ "**nshots** (``int``): Número de disparos "
#~ "de medición. Debe ser un entero "
#~ "positivo."

#~ msgid ""
#~ "**expand_samples** (``bool``): Whether to "
#~ "expand the samples, by default True. "
#~ "If this is True, partial measurements"
#~ " will be returned as \"0_\" where "
#~ "the \"_\" indicates an unmeasured qubit."
#~ " If False, the unmeasured qubits will"
#~ " be dropped from the bitstring, so"
#~ " \"0_\" would be returned as \"0\"."
#~ msgstr ""

#~ msgid "**When to Use It**"
#~ msgstr "**Cuándo Usarlo**"

#~ msgid ""
#~ "Use sampling when you need the "
#~ "full bitstring distribution, for instance "
#~ "to evaluate a combinatorial cost "
#~ "function, run QAOA post-processing, or"
#~ " compute error rates."
#~ msgstr ""
#~ "Use el muestreo cuando necesite la "
#~ "distribución completa de cadenas de "
#~ "bits, por ejemplo para evaluar una "
#~ "función de coste combinatoria, ejecutar "
#~ "el postprocesado de QAOA o calcular "
#~ "tasas de error."

#~ msgid "Expectation Values (with_expectation)"
#~ msgstr "Valores Esperados (with_expectation)"

#~ msgid ""
#~ "Instructs the backend to compute "
#~ "``⟨ψ|O|ψ⟩`` for each observable in the"
#~ " list."
#~ msgstr ""
#~ "Indica al backend que calcule "
#~ "``⟨ψ|O|ψ⟩`` para cada observable de la"
#~ " lista."

#~ msgid ""
#~ "**observables** (``list[Hamiltonian | QTensor]``):"
#~ " The operators whose expectation values "
#~ "are requested.  Each entry can be "
#~ "a :class:`~qilisdk.analog.Hamiltonian` expression "
#~ "(e.g. ``Z(0) + Z(1)``) or a "
#~ ":class:`~qilisdk.core.QTensor` directly."
#~ msgstr ""
#~ "**observables** (``list[Hamiltonian | QTensor]``):"
#~ " Los operadores cuyos valores esperados "
#~ "se solicitan. Cada entrada puede ser "
#~ "una expresión :class:`~qilisdk.analog.Hamiltonian` "
#~ "(por ejemplo ``Z(0) + Z(1)``) o "
#~ "directamente un :class:`~qilisdk.core.QTensor`."

#~ msgid ""
#~ "**nshots** (``int``, default ``0``): Number"
#~ " of shots for stochastic estimation.  "
#~ "``0`` uses the exact state-vector "
#~ "inner product, meaning no sampling "
#~ "noise, only available on simulators."
#~ msgstr ""
#~ "**nshots** (``int``, por defecto ``0``): "
#~ "Número de disparos para la estimación"
#~ " estocástica. ``0`` usa el producto "
#~ "interno exacto del vector de estado, "
#~ "es decir, sin ruido de muestreo; "
#~ "solo disponible en simuladores."

#~ msgid ""
#~ "Use expectation values when you need "
#~ "a scalar energy or observable readout,"
#~ " for example in variational algorithms "
#~ "(VQE, QAOA energy evaluation) or analog"
#~ " time-evolution studies."
#~ msgstr ""
#~ "Use los valores esperados cuando "
#~ "necesite una lectura de energía escalar"
#~ " u observable, por ejemplo en "
#~ "algoritmos variacionales (VQE, evaluación de"
#~ " energía QAOA) o estudios de "
#~ "evolución temporal analógica."

#~ msgid "Full Quantum State (with_state_tomography)"
#~ msgstr "Estado Cuántico Completo (with_state_tomography)"

#~ msgid ""
#~ "Instructs the backend to return the "
#~ "full quantum state vector (or density"
#~ " matrix) after execution."
#~ msgstr ""
#~ "Indica al backend que devuelva el "
#~ "vector de estado cuántico completo (o"
#~ " la matriz de densidad) tras la "
#~ "ejecución."

#~ msgid ""
#~ "**method** (``Literal[\"exact\"]``, default "
#~ "``\"exact\"``): Tomography method.  Currently "
#~ "only ``\"exact\"`` is supported, such "
#~ "that the backend returns the raw "
#~ "state vector."
#~ msgstr ""
#~ "**method** (``Literal[\"exact\"]``, por defecto "
#~ "``\"exact\"``): Método de tomografía. "
#~ "Actualmente solo se admite ``\"exact\"``, "
#~ "de modo que el backend devuelve el"
#~ " vector de estado bruto."

#~ msgid ""
#~ "Use state tomography when you need "
#~ "the complete quantum state for post-"
#~ "processing: computing custom observables "
#~ "offline, visualising the state, checking "
#~ "fidelity, or seeding the next step "
#~ "of a multi-step algorithm."
#~ msgstr ""
#~ "Use la tomografía de estado cuando "
#~ "necesite el estado cuántico completo "
#~ "para el postprocesado: calcular observables"
#~ " personalizados fuera de línea, visualizar"
#~ " el estado, comprobar la fidelidad o"
#~ " alimentar el siguiente paso de un"
#~ " algoritmo de múltiples etapas."

#~ msgid ""
#~ "State tomography is only available on"
#~ " simulators.  Physical QPUs (accessed via"
#~ " :class:`~qilisdk.speqtrum.speqtrum.SpeQtrum`) do not"
#~ " support this readout type."
#~ msgstr ""
#~ "La tomografía de estado solo está "
#~ "disponible en simuladores. Las QPUs "
#~ "físicas (accedidas mediante "
#~ ":class:`~qilisdk.speqtrum.speqtrum.SpeQtrum`) no admiten"
#~ " este tipo de lectura."

#~ msgid "Combining Multiple Readout Types"
#~ msgstr "Combinación de Múltiples Tipos de Lectura"

#~ msgid ""
#~ "Any combination of the three readout "
#~ "types can be requested in a single"
#~ " execution by chaining the ``with_*`` "
#~ "calls.  The backend performs one circuit"
#~ " run and extracts all requested "
#~ "outputs."
#~ msgstr ""
#~ "Cualquier combinación de los tres tipos"
#~ " de lectura puede solicitarse en una"
#~ " única ejecución encadenando las llamadas"
#~ " ``with_*``. El backend realiza una "
#~ "sola ejecución del circuito y extrae "
#~ "todas las salidas solicitadas."

#~ msgid "Accessing Results"
#~ msgstr "Acceso a Resultados"

#~ msgid ""
#~ ":meth:`~qilisdk.backends.backend.Backend.execute` returns "
#~ "a :class:`~qilisdk.functionals.FunctionalResult`.  There"
#~ " are two ways to access the "
#~ "readout data."
#~ msgstr ""
#~ ":meth:`~qilisdk.backends.backend.Backend.execute` devuelve "
#~ "un :class:`~qilisdk.functionals.FunctionalResult`. Hay "
#~ "dos formas de acceder a los datos"
#~ " de lectura."

