msgstr "QiliSDK requiere una versión de Python 3.11 o superior."

#: ../../getting_started/installation.rst:46
msgid "Minimum OS requiremnets:"
msgstr "Requisitos mínimos del sistema operativo:"

#: ../../getting_started/installation.rst:47
msgid "Linux: Ubuntu 22.04 or higher"
msgstr "Linux: Ubuntu 22.04 o superior"

